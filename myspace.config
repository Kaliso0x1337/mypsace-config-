<style>
/* ===== TOP BAR BASE ===== */
.top {
  position: relative;
  padding: 12px 20px;
  border-radius: 10px;
  overflow: hidden;
  max-width: 1200px;
  margin: auto;
  display: flex;
  align-items: center;
  justify-content: center; /* centered if you ever add content */
}

/* ===== GIF/IMAGE BACKGROUND ===== */
.top::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: url('https://media.giphy.com/media/v1.Y2lkPWVjZjA1ZTQ3b2Uwc3BwbnB3dHVsdTFtcnpieG0ycDFuemR1dXRpcnVzbjAydmVoZyZlcD12MV9naWZzX3JlbGF0ZWQmY3Q9Zw/LqWJ4N41G2jCQo0MAp/giphy.gif') 
              no-repeat center/cover;
  opacity: 0.8;
  z-index: 0;
  pointer-events: none; /* allows clicks through GIF */
  filter: blur(1px) brightness(2.5) contrast(1.8) saturate(3) hue-rotate(300deg);
}

/* ===== DARK OVERLAY ===== */
.top::after {
  content: "";
  position: absolute;
  top:0; left:0; right:0; bottom:0;
  background: rgba(0,0,0,0.1);
  z-index: 0;
  pointer-events: none; /* allow clicks through overlay */
}

/* ===== CONTENT ABOVE BACKGROUND ===== */
.top > * {
  position: relative;
  z-index: 1;
}
</style>

