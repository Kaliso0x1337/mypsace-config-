  display: grid;
  grid-auto-flow: column;                /* Fill vertically first, then new column */
  grid-template-rows: repeat(3, 220px);  /* 3 items per column */
  grid-auto-columns: 220px;              /* column width */

  width: 100%;
  height: 700px;                         /* total visible height */
  gap: 20px;
  overflow-x: auto;                      /* horizontal scroll */
  overflow-y: hidden;                     /* hide vertical scrollbar */
  padding: 10px;
  box-sizing: border-box;
}

.vinyl {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 180px;
}

.vinyl img {
  width: 180px;
  height: 180px;
  object-fit: cover;
  transition: transform 0.3s;
}

.vinyl img:hover {
  transform: scale(1.05);
}

.title {
  font-size: 12px;
  text-align: center;
  margin-top: 5px;
}
</style>

