/* BACKGROUND (subtle pattern vibe) */
body {
  background: radial-gradient(circle at center, #1a001f, #000000);
}

/* GRID */
#vinyl-gallery {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  max-width: 700px;
  margin: auto;
  padding: 10px;
  border: 3px solid #a200ff;
  border-radius: 12px;
  background: rgba(0,0,0,0.6);
  box-shadow: 0 0 20px #a200ff;
}

/* VINYL */
.vinyl {
  text-align: center;
  padding: 6px;
  border: 2px dashed #ffe600;
  background: rgba(255,255,255,0.02);
  box-shadow: 0 0 10px #ffe600 inset;
}

/* IMAGE */
.vinyl img {
  width: 100%;
  border-radius: 6px;
  border: 3px solid #ff2ed1;
  transition: 0.3s;
  box-shadow: 0 0 10px #ff2ed1;
}

/* 💿 hover spin + pop */
.vinyl:hover img {
  transform: rotate(6deg) scale(1.08);
  box-shadow: 0 0 20px #ff2ed1, 0 0 30px #a200ff;
}

/* TERMINAL TITLE BOX */
.title {
  margin-top: 8px;
  font-family: 'Silkscreen', monospace;
  background: rgba(0,0,0,0.85);
  padding: 6px;
  border: 2px solid #00ff9f;
  border-radius: 6px;
  font-size: 10px;
  color: #00ff9f;
  text-align: left;
  box-shadow: 0 0 8px #00ff9f;
}

/* prompt */
.title::before {
  content: "> ";
  color: #ffe600;
  text-shadow: 0 0 5px #ffe600;
}

/* STRONG */
.title strong {
  color: #ff2ed1;
  text-shadow: 0 0 6px #ff2ed1;
}

/* EM */
.title em {
  color: #d580ff;
  font-style: italic;
}

/* ⚡ hover glow */
.vinyl:hover .title {
  box-shadow: 0 0 12px #00ff9f, 0 0 25px #a200ff;
}

/* ✨ BLINK EFFECT (optional scene chaos) */
@keyframes blink {
  0% { opacity: 1; }
  50% { opacity: 0.3; }
  100% { opacity: 1; }
}

.title strong {
  animation: blink 1.2s infinite;
}
</style>




<style>
#vinyl-gallery {
  display: grid;
  grid-auto-flow: column;                /* Fill vertically first, then new column */
  grid-template-rows: repeat(3, 220px);  /* 3 items per column */
  grid-auto-columns: 220px;              /* column width */

  width: 100%;
  height: 700px;                         /* total visible height */
  gap: 20px;
  overflow-x: auto;                      /* horizontal scroll */
  overflow-y: hidden;                     /* hide vertical scrollbar */
  padding: 10px;
  box-sizing: border-box;
}

.vinyl {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 180px;
}

.vinyl img {
  width: 180px;
  height: 180px;
  object-fit: cover;
  transition: transform 0.3s;
}

.vinyl img:hover {
  transform: scale(1.05);
}

.title {
  font-size: 12px;
  text-align: center;
  margin-top: 5px;
}
</style>

<div id="vinyl-gallery">
  <div class="vinyl">
    <img src="https://i.scdn.co/image/ab67616d0000b27332003b0b386d6114c0a8a4f9" alt="Album 1"/>
    <div class="title">Album 1</div>
  </div>
  <div class="vinyl">
    <img src="https://i.scdn.co/image/ab67616d0000b273ed83a592d4d82dd977c87459" alt="Album 2"/>
    <div class="title">Album 2</div>
  </div>
  <div class="vinyl">
    <img src="https://i.scdn.co/image/ab67616d0000b273ac512daab17e2a1e90936e6b" alt="Album 3"/>
    <div class="title">Album 3</div>
  </div>

  <div class="vinyl">
    <img src="https://i.scdn.co/image/ab67616d0000b273aed496b26b468213f0f3e9b2" alt="Album 4"/>
    <div class="title">Album 4</div>
  </div>
  <div class="vinyl">
    <img src="https://f4.bcbits.com/img/a2189021492_16.jpg" alt="Album 5"/>
    <div class="title">Album 5</div>
  </div>
  <div class="vinyl">
    <img src="https://i.scdn.co/image/ab67616d0000b273610a8e12b69338515012e35b" alt="Album 6"/>
