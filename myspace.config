<style>
@import url('https://fonts.googleapis.com/css2?family=Silkscreen:wght@400;700&display=swap');

/* BACKGROUND (subtle pattern vibe) */
body {
  background: radial-gradient(circle at center, #1a001f, #000000);
}

/* GRID */
#vinyl-gallery {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  max-width: 700px;
  margin: auto;
  padding: 10px;
  border: 3px solid #a200ff;
  border-radius: 12px;
  background: rgba(0,0,0,0.6);
  box-shadow: 0 0 20px #a200ff;
}

/* VINYL */
.vinyl {
  text-align: center;
  padding: 6px;
  border: 2px dashed #ffe600;
  background: rgba(255,255,255,0.02);
  box-shadow: 0 0 10px #ffe600 inset;
}

/* IMAGE */
.vinyl img {
  width: 100%;
  border-radius: 6px;
  border: 3px solid #ff2ed1;
  transition: 0.3s;
  box-shadow: 0 0 10px #ff2ed1;
}

/* 💿 hover spin + pop */
.vinyl:hover img {
  transform: rotate(6deg) scale(1.08);
  box-shadow: 0 0 20px #ff2ed1, 0 0 30px #a200ff;
}

/* TERMINAL TITLE BOX */
.title {
  margin-top: 8px;
  font-family: 'Silkscreen', monospace;
  background: rgba(0,0,0,0.85);
  padding: 6px;
  border: 2px solid #00ff9f;
  border-radius: 6px;
  font-size: 10px;
  color: #00ff9f;
  text-align: left;
  box-shadow: 0 0 8px #00ff9f;
}

/* prompt */
.title::before {
  content: "> ";
  color: #ffe600;
  text-shadow: 0 0 5px #ffe600;
}

/* STRONG */
.title strong {
  color: #ff2ed1;
  text-shadow: 0 0 6px #ff2ed1;
}

/* EM */
.title em {
  color: #d580ff;
  font-style: italic;
}

/* ⚡ hover glow */
.vinyl:hover .title {
  box-shadow: 0 0 12px #00ff9f, 0 0 25px #a200ff;
}

/* ✨ BLINK EFFECT (optional scene chaos) */
@keyframes blink {
  0% { opacity: 1; }
  50% { opacity: 0.3; }
  100% { opacity: 1; }
}

.title strong {
  animation: blink 1.2s infinite;
}
</style>




